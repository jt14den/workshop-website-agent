#!/usr/bin/env bash
# start-workshop — Paved-path entry point for creating a Carpentries workshop website.
#
# This script:
#   1. Runs preflight checks (tools, auth, YAML validation)
#   2. Shows a summary of the workshop facts
#   3. Offers to run the bootstrap script (repo creation)
#   4. Prints the prompt to paste into your AI agent session
#
# Usage:
#   ./start-workshop              # interactive
#   ./start-workshop --skip-bootstrap   # skip repo creation (already done)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FACTS_FILE="$SCRIPT_DIR/workshop-facts.yaml"
SKIP_BOOTSTRAP=false

for arg in "$@"; do
    case "$arg" in
        --skip-bootstrap) SKIP_BOOTSTRAP=true ;;
        --help|-h)
            echo "Usage: ./start-workshop [--skip-bootstrap]"
            echo ""
            echo "  --skip-bootstrap   Skip repo creation (use if repo already exists)"
            exit 0 ;;
        *) echo "Unknown argument: $arg  (try --help)"; exit 1 ;;
    esac
done

# ---------------------------------------------------------------------------
# Header
# ---------------------------------------------------------------------------

echo ""
echo "=================================================="
echo "  Carpentries Workshop Website — Setup Assistant"
echo "=================================================="
echo ""

# ---------------------------------------------------------------------------
# Check workshop-facts.yaml exists
# ---------------------------------------------------------------------------

if [[ ! -f "$FACTS_FILE" ]]; then
    echo "workshop-facts.yaml not found."
    echo ""
    echo "Copy an example to get started, then fill in your event details:"
    echo ""
    echo "  cp examples/lc-online.yaml workshop-facts.yaml"
    echo "  cp examples/swc-inperson.yaml workshop-facts.yaml"
    echo "  cp examples/dc-multiday.yaml workshop-facts.yaml"
    echo ""
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 1: Preflight
# ---------------------------------------------------------------------------

echo "Step 1 of 3: Preflight checks"
echo ""
if ! bash "$SCRIPT_DIR/scripts/preflight.sh"; then
    echo ""
    echo "Fix the issues above, then re-run:  ./start-workshop"
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 2: Show summary
# ---------------------------------------------------------------------------

echo "Step 2 of 3: Workshop summary"
echo ""

python3 - "$FACTS_FILE" <<'EOF'
import sys, yaml

data = yaml.safe_load(open(sys.argv[1]))

def get(path, default="(not set)"):
    parts = path.split(".")
    obj = data
    for p in parts:
        if not isinstance(obj, dict) or p not in obj:
            return default
        obj = obj[p]
    return obj if obj is not None else default

def list_items(path):
    val = get(path, [])
    if isinstance(val, list):
        return ", ".join(str(v) for v in val if v)
    return str(val)

print(f"  Title:       {get('workshop.title')}")
print(f"  Type:        {get('workshop.carpentry')} / {get('workshop.curriculum')} / {get('workshop.flavor')}")
print(f"  Dates:       {get('event.start_date')} to {get('event.end_date')}  ({get('event.mode')})")
print(f"  Venue:       {get('event.venue')}")
print(f"  Instructors: {list_items('people.instructors')}")
print(f"  Repo:        {get('github.owner')}/{get('github.repo_name')}")
print(f"  Site URL:    https://{get('github.owner')}.github.io/{get('github.repo_name')}/")
print()

# Show TBD fields
def find_tbds(obj, path=""):
    found = []
    if isinstance(obj, str) and obj.strip().upper() == "TBD":
        found.append(path)
    elif isinstance(obj, dict):
        for k, v in obj.items():
            found.extend(find_tbds(v, f"{path}.{k}" if path else k))
    elif isinstance(obj, list):
        for i, item in enumerate(obj):
            found.extend(find_tbds(item, f"{path}[{i}]"))
    return found

tbds = find_tbds(data)
if tbds:
    print(f"  TBD fields ({len(tbds)}):")
    for t in tbds:
        print(f"    - {t}")
    print()
EOF

# ---------------------------------------------------------------------------
# Step 3: Bootstrap (optional)
# ---------------------------------------------------------------------------

if [[ "$SKIP_BOOTSTRAP" == "true" ]]; then
    echo "Step 3 of 3: Bootstrap — skipped (--skip-bootstrap)"
    echo ""
else
    echo "Step 3 of 3: Create the GitHub repository"
    echo ""
    echo "  This will:"
    echo "    - Create the repo from the Carpentries template"
    echo "    - Clone it locally (next to this kit directory)"
    echo "    - Create _includes/syllabus.html"
    echo "    - Enable GitHub Pages"
    echo ""
    read -r -p "  Run a dry-run first to preview? [Y/n] " DRY
    DRY="${DRY:-Y}"
    if [[ "$DRY" =~ ^[Yy]$ ]]; then
        bash "$SCRIPT_DIR/scripts/bootstrap-repo.sh" --dry-run
        echo ""
        read -r -p "  Looks good? Run for real? [y/N] " CONFIRM
        CONFIRM="${CONFIRM:-N}"
        if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
            bash "$SCRIPT_DIR/scripts/bootstrap-repo.sh"
        else
            echo "  Skipped. Re-run ./start-workshop when ready."
            echo ""
        fi
    else
        read -r -p "  Create the repo now? [y/N] " CONFIRM
        CONFIRM="${CONFIRM:-N}"
        if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
            bash "$SCRIPT_DIR/scripts/bootstrap-repo.sh"
        else
            echo "  Skipped. You can run the bootstrap manually:"
            echo "    bash scripts/bootstrap-repo.sh"
            echo ""
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Agent prompt
# ---------------------------------------------------------------------------

echo ""
echo "=================================================="
echo "  Ready to start your agent session"
echo "=================================================="
echo ""
echo "  1. Start your agent CLI from this directory:"
echo ""
echo "       claude          (Claude Code)"
echo "       gemini          (Gemini CLI)"
echo "       gh copilot      (GitHub Copilot CLI)"
echo ""
echo "  2. Paste this prompt to begin:"
echo ""
echo "  ┌─────────────────────────────────────────────────────────────────────┐"
echo "  │ Read instructions/core.md, then workshop-facts.yaml, then help me   │"
echo "  │ configure the Carpentries workshop website. Confirm the facts, then  │"
echo "  │ proceed step by step: _config.yml, index.md front matter, schedule  │"
echo "  │ HTML, and any known fixes needed for this workshop type.             │"
echo "  └─────────────────────────────────────────────────────────────────────┘"
echo ""
echo "  After the agent session, generate your summary:"
echo "    bash scripts/postflight.sh"
echo ""
